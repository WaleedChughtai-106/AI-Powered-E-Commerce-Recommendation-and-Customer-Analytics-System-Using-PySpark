# ─────────────────────────────────────────────────────────────────────────────
# backend/.env  — copy this file to backend/.env and fill in real values.
# Loaded automatically by every script via python-dotenv.
# DO NOT commit the real .env (already in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project (same project as the frontend — see Phase 4 setup).
SUPABASE_URL=https://your-project-ref.supabase.co

# service_role key bypasses RLS. Used by the Spark/psycopg2 writers.
# This key MUST stay on the backend / on your laptop. Never put it in
# the React app and never commit it.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct Postgres connection string for psycopg2 / JDBC.
# Find it in Supabase dashboard → Project Settings → Database → Connection string.
# Use the "URI" form, replace [YOUR-PASSWORD] with the password you set when
# creating the project.
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Where the raw Olist CSVs live on disk (relative to backend/)
RAW_DATA_DIR=data/raw

# Where Spark writes Parquet output (relative to backend/)
PROCESSED_DATA_DIR=data/processed

# Optional: cap Spark driver memory. Default = 2g.
SPARK_DRIVER_MEMORY=2g

# Optional: limit shuffle partitions (200 is overkill for laptop / Olist size)
SPARK_SHUFFLE_PARTITIONS=8
